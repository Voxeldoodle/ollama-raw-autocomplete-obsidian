{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES6",
    "allowJs": true,
    "noImplicitAny": false,
    "moduleResolution": "node",
    "importHelpers": false,
    "isolatedModules": true,
    "strict": false,
    "lib": ["DOM", "ES6", "ES7"]
  },
  "include": ["**/*.ts"]
}
